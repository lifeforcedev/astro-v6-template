{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],

  "schedule": ["on monday before 6am"],
  "prConcurrentLimit": 5,
  "prCreation": "immediate",

  "automerge": false,
  "automergeType": "pr",
  "automergeStrategy": "squash",

  "packageRules": [
    {
      "groupName": "Astro ecosystem",
      "matchPackageNames": ["astro", "@astrojs/**"],
      "automerge": false,
      "addLabels": ["dependencies", "astro"]
    },
    {
      "groupName": "Cloudflare",
      "matchPackageNames": ["wrangler", "@cloudflare/**"],
      "automerge": false,
      "addLabels": ["dependencies", "cloudflare"]
    },
    {
      "groupName": "Tailwind",
      "matchPackageNames": ["tailwindcss", "@tailwindcss/**"],
      "automerge": false,
      "addLabels": ["dependencies", "tailwind"]
    },
    {
      "groupName": "Svelte",
      "matchPackageNames": ["svelte", "@sveltejs/**", "lucide-svelte"],
      "automerge": false,
      "addLabels": ["dependencies", "svelte"]
    },
    {
      "groupName": "Zod",
      "matchPackageNames": ["zod"],
      "automerge": false,
      "addLabels": ["dependencies"]
    },
    {
      "groupName": "Casoon packages",
      "matchPackageNames": ["@casoon/**"],
      "automerge": false,
      "addLabels": ["dependencies", "internal"]
    },
    {
      "groupName": "Dev tools",
      "matchPackageNames": [
        "@biomejs/biome",
        "typescript",
        "tsx",
        "husky",
        "lint-staged",
        "satori",
        "@resvg/resvg-js",
        "clsx",
        "tailwind-merge"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "addLabels": ["dependencies", "dev-tools"]
    },
    {
      "groupName": "Fonts",
      "matchPackageNames": ["@fontsource/**"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "addLabels": ["dependencies", "fonts"]
    },
    {
      "groupName": "Testing",
      "matchPackageNames": ["@playwright/test", "@axe-core/playwright"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "addLabels": ["dependencies", "testing"]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "addLabels": ["dependencies", "ci"]
    }
  ]
}
