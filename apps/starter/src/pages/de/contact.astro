---
import { actions, isInputError } from 'astro:actions';
import Navbar from '@astro-v6/shared/components/Navbar.astro';
import ThemeToggle from '@astro-v6/shared/components/ThemeToggle.svelte';
import BaseLayout from '@astro-v6/shared/layouts/BaseLayout.astro';
import PageSEO from '@astro-v6/shared/seo/PageSEO.astro';
import { localePath } from '@astro-v6/shared/utils/i18n';
import { t } from '@/i18n';
import '@/styles/app.css';

const locale = 'de';
const tr = t(locale);

const links = [
  { href: localePath('/', locale), label: tr('nav.home') },
  { href: localePath('/contact', locale), label: tr('nav.contact') },
];

const result = Astro.getActionResult(actions.submitContactForm);
const success = result && !result.error;
const inputError = result?.error && isInputError(result.error) ? result.error.fields : undefined;
---

<BaseLayout title={tr('contact.title')} description={tr('contact.description')} lang={locale}>
  <PageSEO
    slot="head"
    title={`${tr('contact.title')} - Astro v6 Starter`}
    description={tr('contact.description')}
    ogImage={new URL('/og/de/contact.png', Astro.site).href}
  />

  <Navbar slot="header" siteName="Astro v6" links={links}>
    <a href="/contact" class="text-xs font-medium text-text-secondary hover:text-text no-underline">EN</a>
    <ThemeToggle client:load />
  </Navbar>

  <section class="mx-auto max-w-xl px-6 py-12">
    <h1 class="mb-2 text-3xl font-extrabold">{tr('contact.title')}</h1>
    <p class="mb-8 text-text-secondary">{tr('contact.description')}</p>

    {success && (
      <div class="mb-6 rounded-xl bg-success/20 p-4 text-success" role="status">
        <p>{result.data?.message}</p>
      </div>
    )}

    <form class="flex flex-col gap-4" method="POST" action={actions.submitContactForm}>
      <div class="flex flex-col gap-1">
        <label for="name" class="text-sm font-semibold">{tr('contact.name')}</label>
        <input type="text" id="name" name="name" required autocomplete="name"
          aria-invalid={!!inputError?.name}
          aria-describedby={inputError?.name ? 'name-error' : undefined}
          class="rounded-md border border-border bg-surface px-3 py-2.5 text-text transition-colors focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/15" />
        {inputError?.name && <span id="name-error" class="text-xs text-error" role="alert">{inputError.name}</span>}
      </div>

      <div class="flex flex-col gap-1">
        <label for="email" class="text-sm font-semibold">{tr('contact.email')}</label>
        <input type="email" id="email" name="email" required autocomplete="email"
          aria-invalid={!!inputError?.email}
          aria-describedby={inputError?.email ? 'email-error' : undefined}
          class="rounded-md border border-border bg-surface px-3 py-2.5 text-text transition-colors focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/15" />
        {inputError?.email && <span id="email-error" class="text-xs text-error" role="alert">{inputError.email}</span>}
      </div>

      <div class="flex flex-col gap-1">
        <label for="subject" class="text-sm font-semibold">{tr('contact.subject')}</label>
        <input type="text" id="subject" name="subject" required
          aria-invalid={!!inputError?.subject}
          aria-describedby={inputError?.subject ? 'subject-error' : undefined}
          class="rounded-md border border-border bg-surface px-3 py-2.5 text-text transition-colors focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/15" />
        {inputError?.subject && <span id="subject-error" class="text-xs text-error" role="alert">{inputError.subject}</span>}
      </div>

      <div class="flex flex-col gap-1">
        <label for="message" class="text-sm font-semibold">{tr('contact.message')}</label>
        <textarea id="message" name="message" rows="5" required
          aria-invalid={!!inputError?.message}
          aria-describedby={inputError?.message ? 'message-error' : undefined}
          class="rounded-md border border-border bg-surface px-3 py-2.5 text-text transition-colors focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/15"></textarea>
        {inputError?.message && <span id="message-error" class="text-xs text-error" role="alert">{inputError.message}</span>}
      </div>

      <button type="submit" class="inline-flex cursor-pointer items-center justify-center rounded-md bg-accent px-6 py-3 font-semibold text-text-inverse transition-colors hover:bg-accent-hover">
        {tr('contact.send')}
      </button>
    </form>
  </section>

  <footer slot="footer" class="border-t border-border px-6 py-8 text-center text-sm text-text-secondary">
    <p>&copy; {new Date().getFullYear()} Astro v6 Starter.</p>
  </footer>
</BaseLayout>
