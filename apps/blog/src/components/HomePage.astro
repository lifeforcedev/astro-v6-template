---
import Navbar from '@astro-v6/shared/components/Navbar.astro';
import ThemeToggle from '@astro-v6/shared/components/ThemeToggle.svelte';
import BaseLayout from '@astro-v6/shared/layouts/BaseLayout.astro';
import PageSEO from '@astro-v6/shared/seo/PageSEO.astro';
import type { Locale } from '@astro-v6/shared/utils/i18n';
import { localePath } from '@astro-v6/shared/utils/i18n';
import { t } from '@/i18n';
import type { CollectionEntry } from 'astro:content';

type BlogPost = CollectionEntry<'blog'>;

interface Props {
  locale: Locale;
  posts: BlogPost[];
}

const { locale, posts } = Astro.props;
const tr = t(locale);
const isGerman = locale === 'de';

const links = [{ href: localePath('/', locale), label: tr('nav.home') }];
const ogImage = isGerman ? '/og/de/home.png' : '/og/home.png';
const alternateHref = isGerman ? '/' : '/de';
const alternateLabel = isGerman ? 'EN' : 'DE';
const postPathPrefix = isGerman ? '/de/blog' : '/blog';
const dateLocale = isGerman ? 'de-DE' : 'en-US';
---

<BaseLayout title={tr('home.title')} description={tr('home.description')} lang={locale}>
  <PageSEO
    slot="head"
    title={tr('home.title')}
    description={tr('home.description')}
    ogImage={new URL(ogImage, Astro.site).href}
  />

  <Navbar slot="header" siteName="Astro v6 Blog" links={links}>
    <a href={alternateHref} class="text-xs font-medium text-text-secondary hover:text-text no-underline">{alternateLabel}</a>
    <ThemeToggle client:load />
  </Navbar>

  <section class="mx-auto max-w-3xl px-6 pt-12 pb-8 text-center">
    <h1 class="mb-2 text-[clamp(2rem,5vw,3rem)] font-extrabold tracking-tight">{tr('home.title')}</h1>
    <p class="text-lg text-text-secondary">{tr('home.description')}</p>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-12">
    <h2 class="mb-6 text-2xl font-bold">{tr('home.latest')}</h2>
    <ul class="flex list-none flex-col gap-4 p-0" role="list">
      {posts.map((post: BlogPost) => (
        <li>
          <a href={`${postPathPrefix}/${post.id}`} class="block rounded-xl border border-border bg-surface p-8 no-underline text-inherit transition-all hover:border-accent hover:shadow-md">
            <time datetime={post.data.date.toISOString()} class="mb-1 block text-xs text-text-secondary">
              {post.data.date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h3 class="mb-1 text-xl font-bold">{post.data.title}</h3>
            <p class="leading-relaxed text-text-secondary">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1">
                {post.data.tags.map((tag: string) => (
                  <span class="rounded-full bg-bg-secondary px-2 py-0.5 text-xs text-text-secondary">{tag}</span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <footer slot="footer" class="border-t border-border px-6 py-8 text-center text-sm text-text-secondary">
    <p>
      &copy; {new Date().getFullYear()} Astro v6 Blog.
      <a href="/rss.xml">{tr('footer.rss')}</a>
    </p>
  </footer>
</BaseLayout>
