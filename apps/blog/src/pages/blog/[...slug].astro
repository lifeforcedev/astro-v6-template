---
import { getCollection, render } from 'astro:content';
import Navbar from '@astro-v6/shared/components/Navbar.astro';
import ThemeToggle from '@astro-v6/shared/components/ThemeToggle.svelte';
import BaseLayout from '@astro-v6/shared/layouts/BaseLayout.astro';
import PageSEO from '@astro-v6/shared/seo/PageSEO.astro';
import { localePath, switchLocalePath } from '@astro-v6/shared/utils/i18n';
import { t } from '@/i18n';
import '@/styles/app.css';

const locale = 'en';
const tr = t(locale);

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dePath = switchLocalePath(Astro.url.pathname, 'de');

const links = [{ href: localePath('/', locale), label: tr('nav.home') }];
---

<BaseLayout title={post.data.title} description={post.data.description} lang={locale}>
  <PageSEO
    slot="head"
    title={`${post.data.title} - Astro v6 Blog`}
    description={post.data.description}
    ogType="article"
    ogImage={new URL(`/og/blog/${post.id}.png`, Astro.site).href}
  />

  <Navbar slot="header" siteName="Astro v6 Blog" links={links}>
    <a href={dePath} class="text-xs font-medium text-text-secondary hover:text-text no-underline">DE</a>
    <ThemeToggle client:load />
  </Navbar>

  <article class="mx-auto max-w-3xl px-6 py-12">
    <header class="mb-12">
      <time datetime={post.data.date.toISOString()} class="mb-2 block text-sm text-text-secondary">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="mb-2 text-[clamp(1.75rem,4vw,2.5rem)] font-extrabold leading-snug tracking-tight">{post.data.title}</h1>
      <p class="text-[0.9375rem] text-text-secondary">{tr('post.by')} {post.data.author}</p>
      {post.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1">
          {post.data.tags.map((tag) => (
            <span class="rounded-full bg-bg-secondary px-2 py-0.5 text-xs text-text-secondary">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="mt-12 border-t border-border pt-8">
      <a href={localePath('/', locale)} class="font-semibold">&larr; {tr('post.back')}</a>
    </footer>
  </article>

  <footer slot="footer" class="border-t border-border px-6 py-8 text-center text-sm text-text-secondary">
    <p>&copy; {new Date().getFullYear()} Astro v6 Blog.</p>
  </footer>
</BaseLayout>

<style>
  /* MDX content requires :global() scoped styles — this is the legitimate exception */
  .post-content {
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0.125em 0.375em;
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
  }

  .post-content :global(pre) {
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
    background: var(--color-neutral-900) !important;
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .post-content :global(pre code) {
    padding: 0;
    background: transparent;
  }

  .post-content :global(strong) {
    font-weight: 700;
  }
</style>
