---
import BaseLayout from '@astro-v6/shared/layouts/BaseLayout.astro';
import PageSEO from '@astro-v6/shared/seo/PageSEO.astro';
import { t } from '@/i18n';
import '@/styles/app.css';

const locale = 'en';
const tr = t(locale);
---

<BaseLayout title={tr('404.title')} lang={locale}>
  <PageSEO
    slot="head"
    title={tr('404.title')}
    description={tr('404.text')}
    noIndex
  />
  <div class="flex min-h-[60vh] items-center justify-center px-6" role="alert">
    <div class="max-w-xl text-center">
      <p class="mb-4 text-6xl font-light text-text-secondary">404</p>
      <h1 class="mb-4 text-2xl font-bold md:text-3xl">{tr('404.title')}</h1>
      <p class="mb-8 text-lg text-text-secondary">{tr('404.text')}</p>
      <a href="/" class="inline-block rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white no-underline transition-colors hover:bg-accent/90">
        &larr; {tr('404.back')}
      </a>
    </div>
  </div>
</BaseLayout>
