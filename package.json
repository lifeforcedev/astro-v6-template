{
  "name": "astro-v6-workspace",
  "version": "1.3.0",
  "private": true,
  "description": "Astro v6 monorepo template with pnpm workspaces, Tailwind v4, Svelte 5, and Biome",
  "author": "casoon",
  "license": "MIT",
  "homepage": "https://astrov6.casoon.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/casoon/astro-v6-template"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "dev": "pnpm --filter @astro-v6/starter dev",
    "dev:starter": "pnpm --filter @astro-v6/starter dev",
    "dev:blog": "pnpm --filter @astro-v6/blog dev",
    "build": "pnpm build:starter && pnpm build:blog",
    "build:starter": "pnpm --filter @astro-v6/starter build",
    "build:blog": "pnpm --filter @astro-v6/blog build",
    "preview": "pnpm --filter @astro-v6/starter preview",
    "preview:starter": "pnpm --filter @astro-v6/starter preview",
    "preview:blog": "pnpm --filter @astro-v6/blog preview",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "pnpm -r run type-check",
    "test:e2e": "playwright test",
    "test:e2e:starter": "playwright test --project=starter",
    "test:e2e:blog": "playwright test --project=blog",
    "deploy": "pnpm deploy:starter && pnpm deploy:blog",
    "deploy:starter": "pnpm --filter @astro-v6/starter run deploy",
    "deploy:blog": "pnpm --filter @astro-v6/blog run deploy",
    "secrets:scan": "pnpm exec nosecrets scan .",
    "secrets:scan:staged": "pnpm exec nosecrets scan --staged",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,astro,svelte,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "astro",
    "astro-v6",
    "template",
    "starter",
    "monorepo",
    "workspace",
    "pnpm",
    "catalog",
    "tailwind-v4",
    "svelte-5",
    "biome"
  ],
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@biomejs/biome": "catalog:",
    "@casoon/nosecrets": "^0.3.7",
    "@playwright/test": "^1.59.1",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "sharp": "catalog:"
  },
  "dependencies": {
    "@webspire/mcp": "0.13.0"
  }
}
